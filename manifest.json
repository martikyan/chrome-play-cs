{
  "manifest_version": 3,
  "name": "CS Play Macro & Launcher",
  "version": "6.0.1",
  "description": "Binds keys for play-cs.com",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.play-cs.com/*", "*://*.cs-online.club/*"], 
      "js": ["settings.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": ["activeTab", "storage"],
  "web_accessible_resources": [
    {
      "resources": ["nintendo_switch.mp3"],
      "matches": ["<all_urls>"]
    }
  ]
}